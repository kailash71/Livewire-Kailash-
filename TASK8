#3. Return multiple values (sum, average, min, max) from a list 
def list_details(lst): 
total = sum(lst) 
avg = total / len(lst) 
return total, avg, min(lst), max(lst) 
numbers = [10, 20, 30, 40] 
s, a, mn, mx = list_details(numbers) 
print("Sum:", s, "Average:", a, "Min:", mn, "Max:", mx) 
