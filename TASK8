#7. Simple Interest (default rate = 5%) 
def simple_interest(p, t, r=5): 
return (p * t * r) / 100 
print("SI:", simple_interest(1000, 2)) 
#8. Power of a number (default exponent = 2) 
def power(num, exp=2): 
return num ** exp 
