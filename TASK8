#19. Recursive function to calculate power 
def power(base, exp): 
if exp == 0: 
return 1 
return base * power(base, exp - 1) 
print(power(2, 5)) 
#20. Recursive Fibonacci series up to N terms 
def fibonacci(n): 
if n <= 1: 
return n 
return fibonacci(n-1) + fibonacci(n-2) 
n = 7 
for i in range(n): 
print(fibonacci(i), end=" ")
